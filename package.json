{
  "name": "opencoral",
  "version": "0.1.0",
  "description": "Decentralized LLM desktop client",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "bun test",
    "build:native": "cmake-js build --directory native --out native/build --runtime=electron --runtime-version=33.0.0",
    "clean:native": "cmake-js clean --directory native --out native/build",
    "pack": "npm run build:native && electron-vite build && electron-builder --dir",
    "dist": "npm run build:native && electron-vite build && electron-builder",
    "dist:win": "npm run dist -- --win",
    "dist:mac": "npm run dist -- --mac",
    "dist:linux": "npm run dist -- --linux"
  },
  "cmake-js": {
    "directory": "native",
    "out": "native/build"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/identify": "^4.1.0",
    "@libp2p/kad-dht": "^16.2.0",
    "@libp2p/peer-id": "^6.0.6",
    "@libp2p/ping": "^3.1.0",
    "@libp2p/tcp": "^11.0.15",
    "@multiformats/multiaddr": "^13.0.1",
    "libp2p": "^3.2.0",
    "multiformats": "^13.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "build": {
    "appId": "com.opencoral.app",
    "productName": "OpenCoral",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "native/build/Release/coral_native.node",
        "to": "native/coral_native.node"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "cmake-js": "^8.0.0",
    "electron": "33",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "node-addon-api": "^8.7.0",
    "typescript": "^6.0.2",
    "vite": "6"
  }
}
